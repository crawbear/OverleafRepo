# Compose project name controls Docker volume names.
COMPOSE_PROJECT_NAME=overleafself

# Local bind port for Overleaf web UI
OVERLEAF_PORT=9100

# App metadata
OVERLEAF_APP_NAME=Overleaf Community
OVERLEAF_NAV_TITLE=OverLeafSelf
OVERLEAF_SITE_URL=http://localhost:9100

# Local-only defaults
OVERLEAF_SECURE_COOKIE=false
OVERLEAF_BEHIND_PROXY=false
EMAIL_CONFIRMATION_DISABLED=true

# Change these before first run
OVERLEAF_ADMIN_EMAIL=owner@example.com
OVERLEAF_ADMIN_PASSWORD=change-me-now
